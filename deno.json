{
  "name": "@semantic-loop/core",
  "version": "0.1.0",
  "exports": {
    ".": "./mod.ts"
  },
  "publish": {
    "exclude": ["tests/", "examples/", "docs/", "site/", "pro/", "sql/", ".claude/", "context7.json", ".mcp.json"]
  },
  "tasks": {
    "check": "deno check mod.ts",
    "test": "deno test",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  },
  "compilerOptions": {
    "lib": ["deno.ns", "deno.window"]
  },
  "fmt": {
    "semiColons": true,
    "singleQuote": false,
    "lineWidth": 100
  }
}
